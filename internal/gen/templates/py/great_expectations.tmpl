# Generated by reviewqa for the `{{.Symbol.Name}}` data asset.
#
# Drop under great_expectations/expectations/ and run:
#   great_expectations checkpoint run <checkpoint>
#
# The minimum expectation set per column reviewqa can derive
# deterministically: non-null + type match. Add domain-specific
# expectations by hand.
expectation_suite_name: {{.Symbol.Name | lower}}_suite
expectations:
{{- range .Symbol.Params }}
  - expectation_type: expect_column_to_exist
    kwargs:
      column: {{.Name}}
  - expectation_type: expect_column_values_to_not_be_null
    kwargs:
      column: {{.Name}}
{{- end }}
