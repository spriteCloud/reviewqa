# Generated by quail for dbt model `{{.Symbol.Name}}`.
#
# Drop this YAML next to your dbt model under
#   models/<schema>/<model>.yml
# Run with:
#   dbt test
#
# quail emits the minimum-viable schema-test set per column:
#   unique on identity columns (name matches *_id or "id")
#   not_null on columns the diff added as required
#   accepted_values for any enum-shaped column
version: 2

models:
  - name: {{.Symbol.Name}}
    columns:
{{- range .Symbol.Params }}
      - name: {{.Name}}
        tests:
{{- if isIDColumn .Name }}
          - unique
          - not_null
{{- else if isRequiredField . }}
          - not_null
{{- end }}
{{- end }}
