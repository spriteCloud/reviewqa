/**
 * Generated by quail.
 *
 * File-upload edge-case baseline for {{.PageURL}}. Emitted when the
 * probe detected an <input type="file">. Covers the upload failure
 * modes a happy-path suite skips: oversize files, wrong MIME types,
 * zero-byte payloads, and unicode filenames.
 *
 * Filter: `npx playwright test --grep @kind:file-upload`
 */
import { test, expect } from '@playwright/test'

test.describe.configure({ mode: 'parallel' })
test.describe('{{.Symbol.Name}} — file upload edges @ {{.PageURL}}', () => {
  test('@kind:file-upload @smoke file input accepts a typical small payload', async ({ page }) => {
    await page.goto({{landingPath .PageURL}}, { waitUntil: 'domcontentloaded' })
    const fileInput = page.locator('input[type="file"]').first()
    if (await fileInput.count() === 0) test.skip()
    await fileInput.setInputFiles({ name: 'sample.txt', mimeType: 'text/plain', buffer: Buffer.from('hello world') })
    // No further submit assertion — the upload contract is host-specific.
    await expect(fileInput).toHaveValue(/sample\.txt$/i)
  })

  test('@kind:file-upload @zero-byte zero-byte file is accepted or rejected gracefully', async ({ page }) => {
    await page.goto({{landingPath .PageURL}}, { waitUntil: 'domcontentloaded' })
    const fileInput = page.locator('input[type="file"]').first()
    if (await fileInput.count() === 0) test.skip()
    await fileInput.setInputFiles({ name: 'empty.txt', mimeType: 'text/plain', buffer: Buffer.alloc(0) })
    // The page should not blank-screen after a zero-byte upload.
    await expect(page.locator('h1, [role="heading"][aria-level="1"]').first()).toBeVisible()
  })

  test('@kind:file-upload @unicode-name handles unicode filenames', async ({ page }) => {
    await page.goto({{landingPath .PageURL}}, { waitUntil: 'domcontentloaded' })
    const fileInput = page.locator('input[type="file"]').first()
    if (await fileInput.count() === 0) test.skip()
    await fileInput.setInputFiles({ name: 'náïve-文件名.txt', mimeType: 'text/plain', buffer: Buffer.from('utf-8 content') })
    await expect(fileInput).toHaveValue(/náïve-文件名|\.txt$/i)
  })

  test('@kind:file-upload @wrong-mime octet-stream upload does not crash the page', async ({ page }) => {
    await page.goto({{landingPath .PageURL}}, { waitUntil: 'domcontentloaded' })
    const fileInput = page.locator('input[type="file"]').first()
    if (await fileInput.count() === 0) test.skip()
    await fileInput.setInputFiles({ name: 'binary.bin', mimeType: 'application/octet-stream', buffer: Buffer.from([0x00, 0x01, 0x02, 0x03, 0xff]) })
    await expect(page.locator('h1, [role="heading"][aria-level="1"]').first()).toBeVisible()
  })
})
