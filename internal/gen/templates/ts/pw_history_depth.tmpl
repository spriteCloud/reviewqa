/**
 * Generated by quail.
 *
 * Browser-history depth baseline for {{.PageURL}}. Always emitted per
 * page. Exercises a back → back → forward sequence and asserts the
 * page remains interactive (no blank screen, no React/Vue/etc.
 * unmount errors in console). Catches the common SPA bug where deep
 * history nav leaves the app in a broken state.
 *
 * Filter: `npx playwright test --grep @kind:history-depth`
 */
import { test, expect } from '@playwright/test'

test.describe.configure({ mode: 'parallel' })
test.describe('{{.Symbol.Name}} — history depth @ {{.PageURL}}', () => {
  test('@kind:history-depth @smoke back twice then forward keeps the page interactive', async ({ page }) => {
    const errors: string[] = []
    page.on('pageerror', e => errors.push(e.message))
    page.on('console', m => { if (m.type() === 'error') errors.push(m.text()) })

    await page.goto({{landingPath .PageURL}}, { waitUntil: 'domcontentloaded' })
    const firstLink = page.locator('a[href]:not([href^="#"]):not([href^="mailto:"]):not([href^="tel:"])').first()
    if (await firstLink.count() === 0) test.skip()
    await firstLink.click({ timeout: 5000 }).catch(() => {})
    await page.waitForLoadState('domcontentloaded').catch(() => {})
    const secondLink = page.locator('a[href]:not([href^="#"]):not([href^="mailto:"]):not([href^="tel:"])').first()
    if (await secondLink.count() > 0) {
      await secondLink.click({ timeout: 5000 }).catch(() => {})
      await page.waitForLoadState('domcontentloaded').catch(() => {})
    }
    await page.goBack().catch(() => {})
    await page.goBack().catch(() => {})
    await page.goForward().catch(() => {})
    await page.waitForLoadState('domcontentloaded').catch(() => {})

    // Page is still interactive: h1 is visible, no unhandled exceptions.
    await expect(page.locator('h1, [role="heading"][aria-level="1"]').first()).toBeVisible()
    const unmountErrors = errors.filter(e => /unmount|hydrat|hook|undefined is not/i.test(e))
    expect.soft(unmountErrors, `${unmountErrors.length} framework-unmount errors after history nav`).toEqual([])
  })
})
