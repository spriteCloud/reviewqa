/**
 * Generated by reviewqa from .well-known/apple-app-site-association
 * (or assetlinks.json). Asserts each declared deep-link path returns
 * the same redirect target as the universal-link configuration
 * promises.
 *
 * Filter: `npx playwright test --grep @kind:deeplink`
 */
import { test, expect } from '@playwright/test'

const DEEPLINKS = [
{{- range .Symbol.Anchors }}
  '{{.Name}}',
{{- end }}
]

test.describe.configure({ mode: 'parallel' })
test.describe('{{.Symbol.Name}} — deep links @ {{.PageURL}}', () => {
  for (const path of DEEPLINKS) {
    test(`@kind:deeplink @smoke ${path} resolves`, async ({ request }) => {
      const r = await request.get(new URL(path, '{{.PageURL}}').toString(), { maxRedirects: 0 })
      expect(r.status(), `${path} returned ${r.status()}`).toBeLessThan(500)
    })
  }
})
