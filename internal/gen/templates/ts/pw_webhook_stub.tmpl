/**
 * Generated by quail.
 *
 * Webhook signature-verification stub for {{.PageURL}}. Always
 * emitted per origin. Documents the common webhook-signature
 * conventions (Stripe, GitHub, generic HMAC) and skips until the
 * consumer wires a real signing secret via env.
 *
 * v0.55 — depth parity with pw_api.tmpl. Six tests now: the original
 * signed-vs-unsigned baseline plus five adversarial blocks every
 * webhook receiver must defend (replay, expired timestamp, wrong
 * algorithm, truncated signature, tampered body).
 *
 * Activate by:
 *   1. Set QUAIL_WEBHOOK_ENDPOINT=/path/to/webhook
 *   2. Set QUAIL_WEBHOOK_SECRET=<your-signing-secret>
 *   3. Re-run the suite
 *
 * Filter: `npx playwright test --grep @kind:webhook-stub`
 */
import { test, expect } from '@playwright/test'
import { createHash, createHmac } from 'node:crypto'

const ENDPOINT = process.env.QUAIL_WEBHOOK_ENDPOINT || ''
const SECRET = process.env.QUAIL_WEBHOOK_SECRET || ''

function signSha256(body: string, secret: string): string {
  return createHmac('sha256', secret).update(body).digest('hex')
}

function signMd5(body: string, secret: string): string {
  return createHmac('md5', secret).update(body).digest('hex')
}

// Try common signature header names; return whether any accepted the
// signed POST. Used as a helper so each negative block can compare
// against a known-good baseline.
async function postSigned(request: any, body: string, signature: string, extra: Record<string, string> = {}): Promise<{ status: number, headerUsed: string }> {
  const headerNames = ['X-Hub-Signature-256', 'Stripe-Signature', 'X-Signature']
  for (const name of headerNames) {
    const r = await request.post(ENDPOINT, {
      data: body,
      headers: { 'content-type': 'application/json', [name]: signature, ...extra },
      failOnStatusCode: false,
    })
    if (r.ok()) {
      return { status: r.status(), headerUsed: name }
    }
  }
  return { status: 0, headerUsed: '' }
}

const skipReason = 'set QUAIL_WEBHOOK_ENDPOINT + QUAIL_WEBHOOK_SECRET to activate signature verification'

test.describe.configure({ mode: 'parallel' })
test.describe('{{.Symbol.Name}} — webhook signing @ {{.PageURL}}', () => {
  test('@kind:webhook-stub @smoke signed POST is accepted; unsigned is rejected', async ({ request }) => {
    if (!ENDPOINT || !SECRET) { test.skip(true, skipReason); return }
    const body = JSON.stringify({ ping: 'quail' })
    const signature = signSha256(body, SECRET)
    const { status } = await postSigned(request, body, signature)
    expect.soft(status, 'one of the common signature header names should be accepted with a valid HMAC').toBeGreaterThanOrEqual(200)

    // Unsigned post should NOT be accepted.
    const unsigned = await request.post(ENDPOINT, { data: body, failOnStatusCode: false })
    expect.soft(unsigned.status(), 'unsigned webhook POST should be rejected').toBeGreaterThanOrEqual(400)
  })

  // ─────────────────────────────────────────────────────────────
  // v0.55: five adversarial blocks. Each skips until ENDPOINT+SECRET
  // are wired so the stub is non-disruptive on consumers who haven't
  // declared the surface yet.
  // ─────────────────────────────────────────────────────────────

  test('@kind:webhook-stub @negative replay-attack: same body+signature twice', async ({ request }) => {
    if (!ENDPOINT || !SECRET) { test.skip(true, skipReason); return }
    const body = JSON.stringify({ id: 'quail-replay-' + createHash('sha256').update(SECRET).digest('hex').slice(0, 8) })
    const signature = signSha256(body, SECRET)
    const first = await postSigned(request, body, signature)
    if (first.status === 0) { test.skip(true, 'no signature header accepted; cannot test replay'); return }
    // Repeat — receiver should either reject (4xx — nonce protection)
    // or idempotently re-accept (2xx). What we forbid is a 5xx.
    const second = await request.post(ENDPOINT, {
      data: body,
      headers: { 'content-type': 'application/json', [first.headerUsed]: signature },
      failOnStatusCode: false,
    })
    expect.soft(second.status(), `replay second-attempt status ${second.status()}`).toBeLessThan(500)
  })

  test('@kind:webhook-stub @negative expired-timestamp rejected', async ({ request }) => {
    if (!ENDPOINT || !SECRET) { test.skip(true, skipReason); return }
    const tenMinutesAgo = String(Math.floor(Date.now() / 1000) - 600)
    const body = JSON.stringify({ ping: 'expired' })
    // Stripe-style: timestamp is in the signature material. We sign
    // the (timestamp.body) tuple, then send the timestamp via header
    // so the receiver can recompute. If the receiver doesn't honor
    // timestamps it'll still validate the signature and 200; we soft-
    // assert the rejection so the test doesn't fail on naive servers
    // but the report surfaces the gap.
    const signature = signSha256(tenMinutesAgo + '.' + body, SECRET)
    const r = await request.post(ENDPOINT, {
      data: body,
      headers: {
        'content-type': 'application/json',
        'Stripe-Signature': `t=${tenMinutesAgo},v1=${signature}`,
        'X-Timestamp': tenMinutesAgo,
      },
      failOnStatusCode: false,
    })
    expect.soft(r.status(), 'expired timestamp should be rejected (4xx)').toBeGreaterThanOrEqual(400)
    expect(r.status()).toBeLessThan(500)
  })

  test('@kind:webhook-stub @negative wrong-algorithm signature rejected', async ({ request }) => {
    if (!ENDPOINT || !SECRET) { test.skip(true, skipReason); return }
    const body = JSON.stringify({ ping: 'md5-instead-of-sha256' })
    const badSig = signMd5(body, SECRET)
    const { status } = await postSigned(request, body, badSig)
    // No header accepted (status=0) OR an explicit 4xx is good; what
    // we forbid is 2xx with an HMAC-MD5 signature against a server
    // that should require HMAC-SHA256.
    if (status >= 200 && status < 300) {
      // soft so a permissive receiver doesn't fail the whole spec.
      expect.soft(false, `wrong-algorithm signature accepted with ${status} — receiver should require HMAC-SHA256`).toBe(true)
    } else {
      expect(true).toBe(true)
    }
  })

  test('@kind:webhook-stub @negative truncated-signature rejected', async ({ request }) => {
    if (!ENDPOINT || !SECRET) { test.skip(true, skipReason); return }
    const body = JSON.stringify({ ping: 'truncated' })
    const signature = signSha256(body, SECRET).slice(0, 16)
    const { status } = await postSigned(request, body, signature)
    if (status >= 200 && status < 300) {
      expect.soft(false, `truncated 16-char signature accepted with ${status} — receiver should reject short signatures`).toBe(true)
    } else {
      expect(true).toBe(true)
    }
  })

  test('@kind:webhook-stub @negative tampered-body rejected', async ({ request }) => {
    if (!ENDPOINT || !SECRET) { test.skip(true, skipReason); return }
    const originalBody = JSON.stringify({ amount: 100, currency: 'USD' })
    const tamperedBody = JSON.stringify({ amount: 9999999, currency: 'USD' })
    const signature = signSha256(originalBody, SECRET)
    // Send the tampered body with the signature computed against the
    // original — every receiver MUST reject this; it's the core
    // contract of webhook signing.
    const r = await request.post(ENDPOINT, {
      data: tamperedBody,
      headers: { 'content-type': 'application/json', 'X-Hub-Signature-256': signature },
      failOnStatusCode: false,
    })
    expect.soft(r.status(), 'tampered body must be rejected (signature mismatch is the entire point of webhook signing)').toBeGreaterThanOrEqual(400)
    expect(r.status()).toBeLessThan(500)
  })
})
