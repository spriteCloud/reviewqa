 * Content negotiation for GET {{.PageURL}}. The endpoint advertised
 * multiple response content types — assert each Accept header variant
 * returns the matching Content-Type.
 *
 * Filter: `npx playwright test --grep @kind:api-content-negotiation`
 */
import { test, expect } from '@playwright/test'

const ACCEPT_HEADERS = ['application/json', 'application/xml', 'text/html', 'application/yaml']

test.describe.configure({ mode: 'parallel' })
test.describe('{{.Symbol.Name}} — content negotiation @ {{.PageURL}}', () => {
  for (const accept of ACCEPT_HEADERS) {
    test(`@kind:api-content-negotiation @smoke Accept: ${accept}`, async ({ request }) => {
      const response = await request.get('{{.PageURL}}', {
        headers: { Accept: accept },
      })
      // 200 with matching Content-Type, OR 406 Not Acceptable, OR
      // graceful fallback to the default type. 5xx is a bug.
      expect(response.status(), `Accept: ${accept} returned 5xx`).toBeLessThan(500)
      if (response.status() === 200) {
        const ct = (response.headers()['content-type'] || '').toLowerCase()
        // Loose match: a server returning `application/json; charset=utf-8`
        // satisfies `application/json`.
        expect.soft(ct, `Content-Type ${ct} doesn't satisfy ${accept}`).toContain(accept.split('/')[1])
      }
    })
  }
})
