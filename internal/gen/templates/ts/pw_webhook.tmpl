/**
 * Generated by quail.
 *
 * Webhook contract tests for {{.PageURL}}. Per detected endpoint we
 * emit:
 *   1. @negative — unsigned payload returns 4xx (the textbook
 *      behaviour of a webhook receiver that verifies signatures).
 *   2. @smoke   — signed payload accepted (skipped when WEBHOOK_SECRET
 *      is unset because we can't fake a signature without it).
 *
 * Customise the signing scheme and header name when your provider's
 * convention differs from the GitHub `X-Hub-Signature-256` default.
 *
 * Filter: `npx playwright test --grep @kind:webhook`
 */
import { test, expect } from '@playwright/test'
import { createHmac } from 'node:crypto'

const WEBHOOK_SECRET = process.env.WEBHOOK_SECRET ?? ''

function signPayload(payload: string): string {
  return createHmac('sha256', WEBHOOK_SECRET).update(payload).digest('hex')
}

test.describe.configure({ mode: 'parallel' })
test.describe('{{.Symbol.Name}} — webhooks', () => {
{{- range .Symbol.Anchors }}

  test('@kind:webhook @negative {{.Name}} rejects unsigned payload', async ({ request }) => {
    const response = await request.post('{{.CSS}}', {
      data: { event: 'test', delivery_id: 'quail-probe' },
    })
    // 401/403/400 acceptable — a receiver that verifies signatures
    // refuses unsigned payloads. 404 means "no webhook here" (could
    // happen with provider-pattern probing) and is also acceptable.
    // 2xx means the receiver accepted a payload nobody signed — that's
    // the bug we're looking for.
    expect(response.status(), 'unsigned payload accepted').toBeGreaterThanOrEqual(400)
  })

  test('@kind:webhook @smoke {{.Name}} accepts a signed payload', async ({ request }) => {
    test.skip(!WEBHOOK_SECRET, 'WEBHOOK_SECRET unset — cannot construct a valid signature')
    const payload = JSON.stringify({ event: 'quail.probe', delivery_id: 'quail-probe' })
    const signature = signPayload(payload)
    const response = await request.post('{{.CSS}}', {
      data: payload,
      headers: {
        'Content-Type': 'application/json',
        'X-Hub-Signature-256': `sha256=${signature}`,
        'Stripe-Signature': `t=0,v1=${signature}`,
        'X-Slack-Signature': `v0=${signature}`,
      },
    })
    expect(response.status(), 'signed payload rejected').toBeLessThan(400)
  })
{{- end }}
})
