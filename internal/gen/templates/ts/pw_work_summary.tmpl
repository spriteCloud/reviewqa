<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>reviewqa stakeholder summary — {{.Catalogue.Origin}}</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&family=Inter:wght@400;500;600;900&family=Fira+Code:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --deep-water:  #1B365D;
    --clear-blue:  #4B8BBE;
    --copper:      #C0805A;
    --copper-soft: rgba(192, 128, 90, 0.10);
    --ink:         #0F1117;
    --charcoal:    #1A1D26;
    --graphite:    #2D3748;
    --warm-white:  #FAFAF7;
    --mist:        #8899AA;
    --border-warm: #E8E6E1;
    --white:       #FFFFFF;
    --wm-blue:     #0090D0;
    --wm-gray:     #9DA5AE;
    --bad-fg:      #B91C1C;
    --bad-bg:      #FEE2E2;
    --info-fg:     #4B8BBE;
    --info-bg:     rgba(75,139,190,0.12);
    --ok-fg:       #15803D;
    --ok-bg:       #DCFCE7;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    font-size: 14px;
    line-height: 1.65;
    color: var(--graphite);
    background: var(--warm-white);
    -webkit-font-smoothing: antialiased;
  }
  a { color: var(--clear-blue); text-decoration: none; }
  a:hover { text-decoration: underline; }
  code { font-family: 'Fira Code', ui-monospace, monospace; }

  /* Wordmark — same treatment as web/index.html and serve UI. */
  .wm { font-family: 'Inter', sans-serif; font-weight: 900; letter-spacing: -0.05em; font-size: 18px; }
  .wm .s { color: var(--wm-blue); }
  .wm .c { color: var(--wm-gray); }

  /* COVER BAND */
  .cover {
    background: var(--deep-water);
    color: var(--white);
    padding: 48px 56px 36px;
    position: relative;
  }
  .cover-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 28px;
  }
  .cover .label {
    font-family: 'Fira Code', monospace;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--copper);
  }
  .cover h1 {
    font-family: 'Sora', sans-serif;
    font-weight: 800;
    font-size: clamp(36px, 4.6vw, 52px);
    line-height: 1.04;
    letter-spacing: -0.035em;
    color: var(--white);
    margin: 12px 0 18px;
    word-break: break-word;
  }
  .cover-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    align-items: center;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    color: rgba(255,255,255,0.72);
  }
  .cover-meta .pill {
    font-family: 'Fira Code', monospace;
    font-size: 11px;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: var(--copper);
    background: rgba(192, 128, 90, 0.18);
    padding: 4px 10px;
    border-radius: 6px;
  }
  .cover-meta .dot { color: rgba(255,255,255,0.4); }

  /* PIXEL-RAIL — separator between cover and KPI strip. */
  .pixel-rail {
    background: var(--deep-water);
    padding: 0 0 6px;
    display: flex;
    justify-content: center;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .pixel-rail-inner { display: flex; align-items: flex-end; gap: 4px; height: 80px; }
  .pixel-rail span { display: block; width: 24px; }
  .pr-1  { height: 18px; background: #EDF1F7; }
  .pr-2  { height: 24px; background: #EDF1F7; }
  .pr-3  { height: 30px; background: #D8E2EE; }
  .pr-4  { height: 22px; background: #CADAE8; }
  .pr-5  { height: 36px; background: #CADAE8; }
  .pr-6  { height: 48px; background: #D8E2EE; }
  .pr-7  { height: 40px; background: #CADAE8; }
  .pr-8  { height: 54px; background: #CADAE8; }
  .pr-9  { height: 80px; background: var(--copper); }
  .pr-10 { height: 40px; background: #CADAE8; }
  .pr-11 { height: 56px; background: #CADAE8; }
  .pr-12 { height: 34px; background: #D8E2EE; }
  .pr-13 { height: 42px; background: #D8E2EE; }
  .pr-14 { height: 26px; background: #EDF1F7; }
  .pr-15 { height: 16px; background: #EDF1F7; }

  /* MAIN CONTENT */
  main { padding: 48px 56px 64px; max-width: 1120px; margin: 0 auto; }

  .section { margin-top: 44px; }
  .section:first-child { margin-top: 0; }
  .section-head { margin-bottom: 20px; }
  .section-head .label {
    font-family: 'Fira Code', monospace;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--copper);
  }
  .section-head h2 {
    font-family: 'Sora', sans-serif;
    font-weight: 700;
    font-size: 22px;
    letter-spacing: -0.02em;
    color: var(--deep-water);
    margin-top: 6px;
  }

  /* KPI GRID */
  .kpi-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
  }
  .kpi-card {
    background: var(--white);
    border: 1px solid var(--border-warm);
    border-radius: 12px;
    padding: 24px 22px;
  }
  .kpi-value {
    font-family: 'Sora', sans-serif;
    font-weight: 800;
    font-size: 52px;
    letter-spacing: -0.04em;
    color: var(--deep-water);
    line-height: 1;
    margin-bottom: 10px;
  }
  .kpi-label {
    font-family: 'Fira Code', monospace;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--copper);
  }

  /* PRIORITY BAR */
  .pri-bar {
    width: 100%;
    height: 22px;
    background: var(--border-warm);
    border-radius: 999px;
    overflow: hidden;
    display: flex;
    border: 1px solid var(--border-warm);
  }
  .pri-bar span { display: block; height: 100%; }
  .pri-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 24px;
    margin-top: 14px;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    color: var(--graphite);
  }
  .pri-legend i {
    display: inline-block;
    width: 12px;
    height: 12px;
    border-radius: 3px;
    margin-right: 8px;
    vertical-align: middle;
  }

  /* TABLES */
  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
    background: var(--white);
    border: 1px solid var(--border-warm);
    border-radius: 10px;
    overflow: hidden;
  }
  thead th {
    text-align: left;
    padding: 11px 14px;
    background: var(--copper-soft);
    color: var(--copper);
    font-family: 'Fira Code', monospace;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border-bottom: 1px solid var(--border-warm);
  }
  tbody td {
    padding: 10px 14px;
    border-bottom: 1px solid var(--border-warm);
    color: var(--graphite);
  }
  tbody tr:last-child td { border-bottom: 0; }
  tbody tr:hover { background: var(--copper-soft); }
  tbody td code {
    background: var(--copper-soft);
    color: var(--deep-water);
    padding: 1px 6px;
    border-radius: 4px;
    font-size: 12px;
  }

  /* STATUS PILLS — priority and similar. */
  .pri {
    display: inline-block;
    font-family: 'Fira Code', monospace;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 999px;
    border: 1px solid transparent;
  }
  .pri-critical    { color: var(--bad-fg);  background: var(--bad-bg); }
  .pri-standard    { color: var(--info-fg); background: var(--info-bg); }
  .pri-nice-to-have { color: var(--mist); background: rgba(136, 153, 170, 0.16); }

  .placeholder { color: var(--mist); font-style: italic; padding: 14px 16px; background: var(--white); border: 1px dashed var(--border-warm); border-radius: 10px; }

  /* FOOTER */
  footer {
    background: var(--ink);
    color: rgba(255,255,255,0.6);
    padding: 22px 56px;
    margin-top: 56px;
    font-family: 'Fira Code', monospace;
    font-size: 11px;
    letter-spacing: 0.04em;
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 14px;
  }
  footer a { color: var(--copper); }
  footer code { color: rgba(255,255,255,0.85); }

  @media (max-width: 760px) {
    .kpi-grid { grid-template-columns: repeat(2, 1fr); }
    .cover { padding: 32px 24px 24px; }
    main { padding: 32px 24px 48px; }
    footer { padding: 18px 24px; }
  }
</style>
</head>
<body>
  <header class="cover">
    <div class="cover-head">
      <span class="label">reviewqa · stakeholder summary</span>
      <span class="wm"><span class="s">sprite</span><span class="c">Cloud</span></span>
    </div>
    <h1>{{.Catalogue.Origin}}</h1>
    <div class="cover-meta">
      <span>Generated {{.Catalogue.GeneratedAt}}</span>
      <span class="dot">·</span>
      <span class="pill">{{.Catalogue.CoverageMode}} coverage</span>
      <span class="dot">·</span>
      <span>{{len .Catalogue.Pages}} pages · {{len .Catalogue.Journeys}} journeys · {{len .Catalogue.Fuzz}} fuzz specs</span>
    </div>
  </header>

  <div class="pixel-rail" aria-hidden="true">
    <div class="pixel-rail-inner">
      <span class="pr-1"></span><span class="pr-2"></span><span class="pr-3"></span>
      <span class="pr-4"></span><span class="pr-5"></span><span class="pr-6"></span>
      <span class="pr-7"></span><span class="pr-8"></span><span class="pr-9"></span>
      <span class="pr-10"></span><span class="pr-11"></span><span class="pr-12"></span>
      <span class="pr-13"></span><span class="pr-14"></span><span class="pr-15"></span>
    </div>
  </div>

  <main>
    <section class="section">
      <div class="kpi-grid">
        <div class="kpi-card">
          <div class="kpi-value">{{len .Catalogue.Pages}}</div>
          <div class="kpi-label">Pages crawled</div>
        </div>
        <div class="kpi-card">
          <div class="kpi-value">{{len .Catalogue.Journeys}}</div>
          <div class="kpi-label">Journeys identified</div>
        </div>
        <div class="kpi-card">
          <div class="kpi-value">{{countByPriority .Catalogue.Journeys "critical"}}</div>
          <div class="kpi-label">Critical specs</div>
        </div>
        <div class="kpi-card">
          <div class="kpi-value">{{len .Catalogue.Fuzz}}</div>
          <div class="kpi-label">Fuzz specs</div>
        </div>
      </div>
    </section>

    {{- $crit := countByPriority .Catalogue.Journeys "critical" }}
    {{- $std := countByPriority .Catalogue.Journeys "standard" }}
    {{- $nice := countByPriority .Catalogue.Journeys "nice-to-have" }}
    {{- $total := len .Catalogue.Journeys }}
    <section class="section">
      <div class="section-head">
        <span class="label">Priority mix</span>
        <h2>How the work splits across {{ $total }} journeys.</h2>
      </div>
      {{- if gt $total 0 }}
      <div class="pri-bar" aria-label="Priority distribution bar">
        <span style="width: {{percent $crit $total}}%; background: var(--bad-fg)"></span>
        <span style="width: {{percent $std $total}}%; background: var(--deep-water)"></span>
        <span style="width: {{percent $nice $total}}%; background: var(--mist)"></span>
      </div>
      {{- else }}
      <div class="placeholder">No journeys identified on this probe.</div>
      {{- end }}
      <div class="pri-legend">
        <span><i style="background: var(--bad-fg)"></i>critical ({{$crit}})</span>
        <span><i style="background: var(--deep-water)"></i>standard ({{$std}})</span>
        <span><i style="background: var(--mist)"></i>nice-to-have ({{$nice}})</span>
      </div>
    </section>

    {{- if .Catalogue.Journeys }}
    <section class="section">
      <div class="section-head">
        <span class="label">Journeys</span>
        <h2>Feature files, kinds, priorities.</h2>
      </div>
      <table>
        <thead><tr><th>Feature file</th><th>Kind</th><th>Priority</th><th>Steps</th></tr></thead>
        <tbody>
        {{- range $j := .Catalogue.Journeys }}
          <tr>
            <td><code>{{$j.OutPath}}</code></td>
            <td><code>{{$j.Kind}}</code></td>
            <td><span class="pri pri-{{$j.Priority}}">{{$j.Priority}}</span></td>
            <td>{{len $j.Steps}}</td>
          </tr>
        {{- end }}
        </tbody>
      </table>
    </section>
    {{- end }}

    {{- if .Catalogue.Pages }}
    <section class="section">
      <div class="section-head">
        <span class="label">Pages</span>
        <h2>What reviewqa crawled.</h2>
      </div>
      <table>
        <thead><tr><th>URL</th><th>Title</th></tr></thead>
        <tbody>
        {{- range $p := .Catalogue.Pages }}
          <tr><td><code>{{$p.URL}}</code></td><td>{{if $p.Title}}{{$p.Title}}{{else}}<span style="color: var(--mist); font-style: italic;">(no title)</span>{{end}}</td></tr>
        {{- end }}
        </tbody>
      </table>
    </section>
    {{- end }}
  </main>

  <footer>
    <span>Re-generate with <code>reviewqa probe</code> · published by reviewqa &mdash; by spriteCloud.</span>
    <a href="https://github.com/spriteCloud/reviewqa">github.com/spriteCloud/reviewqa</a>
  </footer>
</body>
</html>
