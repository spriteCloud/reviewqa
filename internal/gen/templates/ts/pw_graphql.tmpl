      const allValidation = body.errors.every((e: any) =>
        (e.extensions?.code || '').match(/INVALID|VALIDATION|BAD_REQUEST/i))
      expect.soft(allValidation, JSON.stringify(body.errors)).toBe(true)
    } else {
