import { GenericContainer, Wait } from 'testcontainers'

describe('{{.Integration.Database.Name}} — round-trip @kind:integration-db', () => {
  let container: any
  let connectionString = ''

  beforeAll(async () => {
    container = await new GenericContainer('{{.Integration.Database.Image}}')
      .withExposedPorts(5432)
      .withEnvironment({
        POSTGRES_PASSWORD: 'quail',
        POSTGRES_USER: 'quail',
        POSTGRES_DB: '{{.Integration.Database.Name}}',
      })
      .withWaitStrategy(Wait.forLogMessage('database system is ready to accept connections'))
      .start()
    const host = container.getHost()
    const port = container.getMappedPort(5432)
    connectionString = `postgresql://quail:quail@${host}:${port}/{{.Integration.Database.Name}}`
  }, 120_000)

  afterAll(async () => {
    if (container) await container.stop()
  })

  it('@kind:integration-db CREATE / INSERT / SELECT / DELETE round-trip', async () => {
