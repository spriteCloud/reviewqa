import { GenericContainer, Wait } from 'testcontainers'

describe('{{.Integration.Cache.Kind}} cache round-trip @kind:integration-cache', () => {
  let container: any
  let connStr = ''

  beforeAll(async () => {
    container = await new GenericContainer('{{.Integration.Cache.Image}}')
      .withExposedPorts(6379)
      .withWaitStrategy(Wait.forListeningPorts())
      .start()
    connStr = `redis://${container.getHost()}:${container.getMappedPort(6379)}`
  }, 60_000)

  afterAll(async () => {
    if (container) await container.stop()
  })

  it('@kind:integration-cache write-then-read returns the same value', async () => {
    // Wire up your client (ioredis, node-redis, memcache) using connStr.
    expect(connStr).toContain('redis://')
