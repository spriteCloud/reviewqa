/**
 * Generated by quail.
 *
 * Drag-and-drop baseline for {{.PageURL}}. Emitted when the probe
 * detected an element with [draggable] or a [ondrop] handler. Asserts
 * a basic drag sequence does not crash the page, and that the drop
 * zone reports the dropped item via aria-live or DOM mutation.
 *
 * Filter: `npx playwright test --grep @kind:dragdrop`
 */
import { test, expect } from '@playwright/test'

test.describe.configure({ mode: 'parallel' })
test.describe('{{.Symbol.Name}} — dragdrop @ {{.PageURL}}', () => {
  test('@kind:dragdrop @smoke drag-and-drop does not crash the page', async ({ page }) => {
    await page.goto({{landingPath .PageURL}})
    const draggable = page.locator('[draggable="true"], [draggable]').first()
    const dropZone = page.locator('[ondrop], [data-dropzone], [role="region"]').first()
    if (await draggable.count() === 0) test.skip()
    if (await dropZone.count() === 0) test.skip()
    try {
      await draggable.dragTo(dropZone, { timeout: 3000 })
    } catch {
      // Some sites use HTML5 DataTransfer events that Playwright's
      // dragTo cannot drive without an explicit polyfill. Failure to
      // drive the drag is NOT a regression — only a page crash is.
    }
    await expect(page.locator('h1, [role="heading"][aria-level="1"]').first()).toBeVisible()
  })
})
