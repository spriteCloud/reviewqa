/**
 * Generated by reviewqa.
 *
 * Date-input edge-case baseline for {{.PageURL}}. Emitted when probe
 * detected an <input type="date"> or type="datetime-local". Covers
 * the boundary dates that hide off-by-one bugs in date parsing:
 * leap-year, DST transition, y2038 boundary.
 *
 * Filter: `npx playwright test --grep @kind:date-edges`
 */
import { test, expect } from '@playwright/test'

const DATE_BOUNDARIES: { label: string; value: string }[] = [
  { label: 'leap-year-feb-29', value: '2024-02-29' },
  { label: 'leap-year-non',    value: '2023-02-29' }, // invalid; browser should reject or normalize
  { label: 'dst-transition',   value: '2024-03-10' }, // US DST begin
  { label: 'y2038-boundary',   value: '2038-01-19' }, // 32-bit int_t overflow
  { label: 'far-future',       value: '9999-12-31' },
  { label: 'epoch',            value: '1970-01-01' },
]

test.describe.configure({ mode: 'parallel' })
test.describe('{{.Symbol.Name}} — date edges @ {{.PageURL}}', () => {
  for (const b of DATE_BOUNDARIES) {
    test(`@kind:date-edges @smoke ${b.label}`, async ({ page }) => {
      await page.goto({{landingPath .PageURL}})
      const dateInput = page.locator('input[type="date"], input[type="datetime-local"]').first()
      if (await dateInput.count() === 0) test.skip()
      await dateInput.fill(b.value).catch(() => {})
      // Page should still render the h1 after a boundary fill.
      await expect(page.locator('h1, [role="heading"][aria-level="1"]').first()).toBeVisible()
    })
  }
})
