/**
 * Generated by quail.
 *
 * Locale-switch baseline for {{.PageURL}}. Emitted when the probe
 * detected hreflang siblings. Verifies switching from one locale to
 * another mid-session preserves the user's place — the next page in
 * the journey should respect the new locale, not silently revert.
 *
 * Filter: `npx playwright test --grep @kind:locale-switch`
 */
import { test, expect } from '@playwright/test'

type Locale = { lang: string; url: string }

const LOCALES: Locale[] = [
{{- range $lang, $url := .Symbol.Meta.Hreflang }}
  { lang: '{{$lang}}', url: '{{$url}}' },
{{- end }}
]

test.describe.configure({ mode: 'parallel' })
test.describe('{{.Symbol.Name}} — locale switch @ {{.PageURL}}', () => {
  test('@kind:locale-switch @smoke switching locales preserves the user on the same logical page', async ({ page }) => {
    if (LOCALES.length < 2) test.skip()
    // Visit two distinct locales in sequence; both should respond and
    // present a non-empty <h1>.
    for (const locale of LOCALES.slice(0, 2)) {
      const response = await page.goto(locale.url)
      expect.soft(response?.status() ?? 0, `locale ${locale.lang} should respond <400`).toBeLessThan(400)
      await expect(page.locator('h1, [role="heading"][aria-level="1"]').first()).toBeVisible()
      const htmlLang = await page.locator('html').getAttribute('lang')
      const expected = locale.lang.split('-')[0].toLowerCase()
      const actual = (htmlLang || '').split('-')[0].toLowerCase()
      expect.soft(actual, `<html lang> should reflect locale ${locale.lang} after navigation`).toBe(expected)
    }
  })
})
