/**
 * Generated by quail. Fuzz spec for {{.PageURL}}.
 *
 * Bounded negative-coverage: each text input + interactive component on
 * this page gets exercised with edge-case payloads (empty, very long,
 * special chars) to surface input-handling bugs the happy-path specs
 * skip over. Capped at 5 emissions per page so triage stays tractable.
 *
 * Filter: `npx playwright test --grep @fuzz`
 */
import { test, expect } from './_fixtures'

test.describe.configure({ mode: 'parallel' })
test.describe('{{.Symbol.Name}} — fuzz / negative input', () => {
  test.beforeEach(async ({ page }) => {
    await page.goto({{landingPath .PageURL}})
  })
{{- /* Fuzz inputs: one bounded test per text-like field, three payloads
       (empty / long / special chars). Hidden, password, and submit-type
       inputs are filtered upstream by the pattern registry. */ -}}
{{- $inputCount := 0 }}
{{- range $i := .Symbol.Inputs }}
{{- if and (lt $inputCount 3) (or (eq $i.Type "text") (eq $i.Type "email") (eq $i.Type "search") (eq $i.Type "url") (eq $i.Type "tel") (eq $i.Type "textarea")) }}
{{- $iloc := inputLocator $i }}
{{- if $iloc }}
{{- $inputCount = (add $inputCount 1) }}

  test('@fuzz @negative input "{{or $i.Name $i.Placeholder $i.Aria "field"}}" handles edge payloads', async ({ page }) => {
    const field = page.{{$iloc}}.first()
    // Empty value: should be accepted by the field itself (validation
    // surfaces only on submit).
    await field.fill('')
    await expect(field).toHaveValue('')
    // Very long input (5000 chars): field should not crash or hang.
    const long = 'x'.repeat(5000)
    await field.fill(long)
    const persisted = await field.inputValue()
    expect(persisted.length).toBeGreaterThan(0)
    // Special-character payload: HTML-injection shape. Must not execute
    // (handled by the pageErrors fixture in _fixtures.ts).
    await field.fill('\'><script>alert(1)</script>')
    await expect(field).toBeAttached()
  })
{{- end }}
{{- end }}
{{- end }}
{{- /* Keyboard-only exercise for interactive components. Capped at 2. */ -}}
{{- $kbdCount := 0 }}
{{- range $ix := .Symbol.Interactions }}
{{- if and (lt $kbdCount 2) (or (eq $ix.Kind "details") (eq $ix.Kind "collapse") (eq $ix.Kind "tab") (eq $ix.Kind "popup")) }}
{{- $kbdCount = (add $kbdCount 1) }}

  test('@fuzz @keyboard {{$ix.Kind}}{{if $ix.Text}} ({{$ix.Text}}){{end}} responds to Tab + Enter', async ({ page }) => {
    // Tab through the page looking for the trigger, then activate via
    // keyboard. Catches focus-trap and missing-keyboard-handler bugs
    // that mouse-only tests miss.
    const target = page.{{interactionLocator $ix}}.first()
    await target.focus()
    await page.keyboard.press('Enter')
    // No assertion on resulting state — interactions vary by kind.
    // The pageErrors fixture catches any uncaught JS the keyboard
    // path triggered.
    await expect(target).toBeAttached()
  })
{{- end }}
{{- end }}
})
