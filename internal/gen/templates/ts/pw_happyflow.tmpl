/**
 * Generated by reviewqa.
 *
 * Journey kind: {{if .JourneyKind}}{{.JourneyKind}}{{else}}page-happy-flow{{end}}
 * Entry page:   {{.PageURL}}
 * Steps:        {{len .Symbols}}
 *
 * Filter to this kind with: `npx playwright test --grep @journey:{{.JourneyKind}}`
 * Filter to all smokes: `npx playwright test --grep @smoke`
 *
 * Stable signals (hard assertions) drive the journey: URL changes,
 * h1 visibility, form submit. Nice-to-have signals (h2 sub-headings,
 * image alt, meta tags) are `expect.soft` so a copy edit doesn't
 * cascade-fail the whole test.
 */
import { test, expect } from './_fixtures'

test.describe.configure({ mode: 'parallel' })
test.describe('{{.Symbol.Name}}{{if .JourneyKind}} — {{.JourneyKind}} journey{{else}} page happy flow{{end}}', () => {
  // Page-error tracking is automatic via the `pageErrors` fixture in
  // _fixtures.ts (auto:true). Each test still needs to navigate to
  // the landing page itself — the path is baseURL-relative so the
  // same suite can run against staging / a PR preview / localhost by
  // setting BASE_URL.
  test.beforeEach(async ({ page }) => {
    await page.goto({{landingPath .PageURL}})
  })
{{- if eq .JourneyKind "exercise" }}
{{- range $i := .Symbol.Interactions }}
{{- $loc := interactionLocator $i }}
{{- if eq $i.Kind "search" }}

  test('@journey:exercise @smoke exercise: search box accepts input and navigates', async ({ page }) => {
    const box = page.{{$loc}}.first()
    await box.fill('{{fillValueForInteraction $i}}')
    await box.press('Enter')
    // Either the URL changed (search results page) or a results region appeared.
    await page.waitForLoadState('domcontentloaded')
  })
{{- else if eq $i.Kind "dialog" }}

  test('@journey:exercise @smoke exercise: dialog opens and closes', async ({ page }) => {
    const dialog = page.{{$loc}}.first()
    // The dialog may already be open in HTML (popovertarget pattern) or
    // require a trigger click. We only assert open + escape-to-close.
    await expect(dialog).toBeAttached()
  })
{{- else if eq $i.Kind "details" }}

  test('@journey:exercise @smoke exercise: details element expands and collapses{{if $i.Text}} ({{$i.Text}}){{end}}', async ({ page }) => {
    const d = page.{{$loc}}.first()
    await expect(d).toHaveJSProperty('open', false)
    await d.locator('summary').first().click()
    await expect(d).toHaveJSProperty('open', true)
    await d.locator('summary').first().click()
    await expect(d).toHaveJSProperty('open', false)
  })
{{- else if eq $i.Kind "collapse" }}

  test('@journey:exercise @smoke exercise: collapse toggle flips aria-expanded{{if $i.Text}} ({{$i.Text}}){{end}}', async ({ page }) => {
    const trigger = page.{{$loc}}.first()
    const before = await trigger.getAttribute('aria-expanded')
    await trigger.click()
    const after = await trigger.getAttribute('aria-expanded')
    expect(after).not.toBe(before)
  })
{{- else if eq $i.Kind "tab" }}

  test('@journey:exercise @smoke exercise: tab activates{{if $i.Text}} ({{$i.Text}}){{end}}', async ({ page }) => {
    const tab = page.{{$loc}}.first()
    await tab.click()
    await expect(tab).toHaveAttribute('aria-selected', 'true')
  })
{{- else if eq $i.Kind "date" }}

  test('@journey:exercise @smoke exercise: {{$i.InputType}} input accepts a value', async ({ page }) => {
    const input = page.{{$loc}}.first()
    await input.fill('{{fillValueForInteraction $i}}')
    await expect(input).toHaveValue('{{fillValueForInteraction $i}}')
  })
{{- else if eq $i.Kind "data-toggle" }}

  test('@journey:exercise @smoke exercise: {{$i.Toggle}} toggle responds to click{{if $i.Text}} ({{$i.Text}}){{end}}', async ({ page }) => {
    const trigger = page.{{$loc}}.first()
    const before = await trigger.getAttribute('aria-expanded')
    await trigger.click()
    // Poll for a state change instead of waiting a fixed time:
    // either aria-expanded flips, or a [role=dialog] becomes visible.
    await expect.poll(async () => {
      const after = await trigger.getAttribute('aria-expanded')
      if (after !== before) return true
      return await page.locator('[role="dialog"]').first().isVisible().catch(() => false)
    }, { timeout: 2000, message: 'expected aria-expanded to flip or a dialog to appear after toggle click' }).toBe(true)
  })
{{- else if eq $i.Kind "popup" }}

  test('@journey:exercise @smoke exercise: popup trigger reveals menu{{if $i.Text}} ({{$i.Text}}){{end}}', async ({ page }) => {
    const trigger = page.{{$loc}}.first()
    await trigger.click()
    // After clicking, an aria-expanded flip OR a visible menu/listbox.
    const expanded = await trigger.getAttribute('aria-expanded')
    const menuVisible = await page.locator('[role="menu"], [role="listbox"]').first().isVisible().catch(() => false)
    expect(expanded === 'true' || menuVisible).toBeTruthy()
  })
{{- end }}
{{- end }}
{{- else }}
{{- if hasKnownFailurePattern .Symbol }}
  // Marked test.fail() because reviewqa detected a known-broken pattern
  // on this page: the submit element carries a `data-wait` attribute,
  // indicating a Webflow / similar form whose Submit button stays
  // disabled until client-side JS validates the input. Playwright's
  // .fill() doesn't trigger the same blur/change events a real user
  // would, so the click() will time out on the disabled submit. Remove
  // this annotation once the underlying form handling is sorted.
  test.fail('{{if .JourneyKind}}@journey:{{.JourneyKind}} @smoke {{.JourneyKind}}: {{end}}full user journey ({{len .Symbols}} step(s))', async ({ page }) => {
{{- else }}
  test('{{if .JourneyKind}}@journey:{{.JourneyKind}} @smoke {{.JourneyKind}}: {{end}}full user journey ({{len .Symbols}} step(s))', async ({ page }) => {
{{- end }}
{{- range $idx, $s := .Symbols }}
{{- $intent := intentFor $s }}
{{- if eq $idx 0 }}
    // Step 1 — visit landing (intent: {{$intent}}) — handled by beforeEach
{{- else if $s.EnteredVia }}
{{- if $s.DirectGoto }}

    await test.step('Step {{add $idx 1}} — direct goto "{{$s.EnteredVia}}"', async () => {
      await page.goto('{{$s.EnteredVia}}')
      await expect(page).toHaveURL(new RegExp('{{$s.EnteredVia}}$'))
    })
{{- else }}

    await test.step('Step {{add $idx 1}} — click "{{$s.EnteredVia}}"', async () => {
      const link = page.locator('a[href="{{$s.EnteredVia}}"], [href="{{$s.EnteredVia}}"]').first()
      try {
        await link.click({ timeout: 3000 })
      } catch {
        // Link is in the DOM but not directly clickable (often a hover-only
        // dropdown menu item). Navigate by URL so the destination still gets
        // exercised instead of the whole spec hard-failing on the menu.
        await page.goto('{{$s.EnteredVia}}')
      }
      await expect(page).toHaveURL(new RegExp('{{$s.EnteredVia}}$'))
    })
{{- end }}
{{- else }}

    // Step {{add $idx 1}} — {{$s.Name}} (same page, intent: {{$intent}})
{{- end }}
{{- $landingTitle := (index $.Symbols 0).PageTitle }}
{{- if $s.PageTitle }}
{{- if or (eq $idx 0) (ne $s.PageTitle $landingTitle) }}
    await expect(page).toHaveTitle(/{{regexEscape $s.PageTitle}}/i)
{{- end }}
{{- end }}
{{- $h1 := firstH1 $s.Contents }}
{{- if $h1.Text }}
    await expect(page.{{contentLocator $h1}}.first()).toBeVisible()
{{- end }}
{{- /* Per-step h2 emit (capped at 2). Attached not visible so CSS-hidden
       SEO h2s still match. Soft so renamed sub-heading doesn't cascade. */ -}}
{{- range $h2 := firstH2s $s.Contents 2 }}
    await expect.soft(page.{{contentLocator $h2}}.first()).toBeAttached()
{{- end }}
{{- /* Landing-step image alt-text presence (cap 2) and SEO assertions. */ -}}
{{- if eq $idx 0 }}
{{- range $img := topImages $s.Images 2 }}
    await expect.soft(page.getByAltText(/{{regexEscape $img.Alt}}/i).first()).toBeAttached()
{{- end }}
{{- if or (eq $.JourneyKind "read") (eq $.JourneyKind "research") }}
{{- if $s.Meta.Description }}
    await expect.soft(page.locator('meta[name="description"]')).toHaveAttribute('content', /{{regexEscape $s.Meta.Description}}/i)
{{- end }}
{{- if $s.Meta.OGTitle }}
    await expect.soft(page.locator('meta[property="og:title"]')).toHaveAttribute('content', /{{regexEscape $s.Meta.OGTitle}}/i)
{{- end }}
{{- end }}
{{- end }}
{{- range $a := $s.Anchors }}
{{- $loc := locatorFor $a }}
{{- if $loc }}
{{- if and (ne $idx 0) (eq $a.Role "banner") }}
{{- else }}
    await expect(page.{{$loc}}.first()).toBeVisible()
{{- end }}
{{- end }}
{{- end }}
{{- if not $s.Anchors }}
{{- range $c := $s.Contents }}
{{- if or (eq $c.Tag "h2") (eq $c.Tag "cta") }}
    await expect(page.{{contentLocator $c}}.first()).toBeVisible()
{{- end }}
{{- end }}
{{- end }}
{{- if eq $intent "form" }}
{{- if $s.Inputs }}
    // Fill form
{{- range $i := $s.Inputs }}
{{- $iloc := inputLocator $i }}
{{- if not $iloc }}
    // SKIP: input on line {{$i.Line}} has no stable locator — add data-testid
{{- else if shouldCheck $i }}
    await page.{{$iloc}}.first().check()
{{- else if eq $i.Type "select" }}
    await page.{{$iloc}}.first().selectOption({ index: 0 })
{{- else }}
{{- with locatorProvenance $i }}
    // note: using <{{.}}> as locator — no data-testid on the input
{{- end }}
    await page.{{$iloc}}.first().fill('{{fillValueFor $i}}')
{{- end }}
{{- end }}
{{- end }}
{{- with firstSubmit $s.Anchors }}{{ $sub := index . 0 }}
{{- $subloc := locatorFor $sub }}
{{- if $subloc }}
    await page.{{$subloc}}.first().click()
{{- end }}
{{- end }}
    // Scoped to the form region (not the whole page) so unrelated
    // marketing copy containing "error" / "failed" doesn't false-positive.
    await expect(page.locator('form, [role="form"]').first().locator('text=/error|failed/i')).toHaveCount(0)
{{- end }}
{{- if eq $intent "content" }}
{{- with firstClickable $s.Anchors }}{{ $a := index . 0 }}
{{- if $s.HasOnClick }}
    {
      const target = page.{{locatorFor $a}}.first()
      await target.click()
      await expect(target).toBeVisible()
{{- if $s.HasState }}
      const before = await target.getAttribute('aria-expanded')
      await target.click()
      const after = await target.getAttribute('aria-expanded')
      expect(after).not.toBe(before)
{{- end }}
    }
{{- end }}
{{- end }}
{{- end }}
{{- if and (eq $intent "nav") (eq (len $.Symbols) 1) }}
{{- range $l := rankedNavTargetsRotated $s.Links $s.EnteredVia $s.EnteredVia }}

    await test.step('Step {{add $idx 2}} — outbound click "{{linkHref $l}}"', async () => {
      const link = page.locator('a[href="{{linkHref $l}}"], [href="{{linkHref $l}}"]').first()
      await link.click()
      await expect(page).toHaveURL(new RegExp('{{linkHref $l}}$'))
    })
{{- end }}
{{- end }}
{{- end }}
  })
{{- end }}{{/* end of if-exercise/else */}}
{{- range $s := .Symbols }}
{{- if and (eq (intentFor $s) "form") $s.HasOnSubmit (hasRequiredInput $s.Inputs) }}
{{- with firstSubmit $s.Anchors }}{{ $sub := index . 0 }}
{{- $subloc := locatorFor $sub }}
{{- with firstRequiredInput $s.Inputs }}{{ $req := index . 0 }}
{{- $reqloc := inputLocator $req }}
{{- if and $subloc $reqloc }}

  test('@journey:{{$.JourneyKind}} @negative {{$.Symbol.Name}}: {{$s.Name}} blocks submit when required fields are empty', async ({ page }) => {
    await page.{{$subloc}}.first().click()
    await expect(page.{{$reqloc}}.first()).toBeVisible()
    await expect(page.locator('text=/success|welcome|signed in/i')).toHaveCount(0)
  })
{{- end }}
{{- end }}
{{- end }}
{{- end }}
{{- end }}
})
