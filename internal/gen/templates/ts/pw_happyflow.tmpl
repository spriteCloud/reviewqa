// Generated by reviewqa. Single-page happy flow: navigate, walk, fill, submit, advance.
import { test, expect } from '@playwright/test'

{{- if isAbsoluteURL .PageURL }}
const TARGET = '{{.PageURL}}'
{{- else }}
const BASE = process.env.BASE_URL ?? 'http://localhost:3000'
const TARGET = BASE + '{{.PageURL}}'
{{- end }}

test.describe('{{.Symbol.Name}} page happy flow', () => {
  test.beforeEach(async ({ page }) => { await page.goto(TARGET) })

  test('walks {{len .Symbols}} component(s) on {{.PageURL}}', async ({ page }) => {
{{- range $s := .Symbols }}
{{- $intent := intentFor $s }}
    // --- {{$s.Name}} (intent: {{$intent}}) ---
{{- range $a := $s.Anchors }}
{{- $loc := locatorFor $a }}
{{- if $loc }}
    await expect(page.{{$loc}}.first()).toBeVisible()
{{- end }}
{{- end }}
{{- if eq $intent "form" }}
{{- if $s.Inputs }}
    // Fill form
{{- range $i := $s.Inputs }}
{{- $iloc := inputLocator $i }}
{{- if not $iloc }}
    // SKIP: input on line {{$i.Line}} has no stable locator — add data-testid
{{- else if shouldCheck $i }}
    await page.{{$iloc}}.first().check()
{{- else if eq $i.Type "select" }}
    await page.{{$iloc}}.first().selectOption({ index: 0 })
{{- else }}
{{- with locatorProvenance $i }}
    // note: using <{{.}}> as locator — no data-testid on the input
{{- end }}
    await page.{{$iloc}}.first().fill('{{fillValueFor $i}}')
{{- end }}
{{- end }}
{{- end }}
{{- with firstSubmit $s.Anchors }}{{ $sub := index . 0 }}
{{- $subloc := locatorFor $sub }}
{{- if $subloc }}
    await page.{{$subloc}}.first().click()
{{- end }}
{{- end }}
    await expect(page.locator('text=/error|failed/i')).toHaveCount(0)
{{- end }}
{{- if eq $intent "nav" }}
{{- with firstSameOriginLink $s.Links }}{{ $l := index . 0 }}
    // Navigate via first same-origin link.
    {
      const link = page.locator('a[href="{{linkHref $l}}"], [href="{{linkHref $l}}"]').first()
      await link.click()
      await expect(page).toHaveURL(new RegExp('{{linkHref $l}}$'))
    }
{{- end }}
{{- end }}
{{- if eq $intent "content" }}
{{- with firstClickable $s.Anchors }}{{ $a := index . 0 }}
{{- if $s.HasOnClick }}
    {
      const target = page.{{locatorFor $a}}.first()
      await target.click()
      await expect(target).toBeVisible()
{{- if $s.HasState }}
      const before = await target.getAttribute('aria-expanded')
      await target.click()
      const after = await target.getAttribute('aria-expanded')
      expect(after).not.toBe(before)
{{- end }}
    }
{{- end }}
{{- end }}
{{- if not $s.HasOnClick }}
    // No form / nav / interactive signals detected on {{$s.Name}} — only visibility is asserted.
    // TODO: extend with stable locators (add data-testid attributes).
{{- end }}
{{- end }}
{{- end }}
  })
{{- range $s := .Symbols }}
{{- if and (eq (intentFor $s) "form") $s.HasOnSubmit (hasRequiredInput $s.Inputs) }}
{{- with firstSubmit $s.Anchors }}{{ $sub := index . 0 }}
{{- $subloc := locatorFor $sub }}
{{- with firstRequiredInput $s.Inputs }}{{ $req := index . 0 }}
{{- $reqloc := inputLocator $req }}
{{- if and $subloc $reqloc }}

  test('{{$.Symbol.Name}}: {{$s.Name}} blocks submit when required fields are empty', async ({ page }) => {
    await page.{{$subloc}}.first().click()
    await expect(page.{{$reqloc}}.first()).toBeVisible()
    await expect(page.locator('text=/success|welcome|signed in/i')).toHaveCount(0)
  })
{{- end }}
{{- end }}
{{- end }}
{{- end }}
{{- end }}
})
