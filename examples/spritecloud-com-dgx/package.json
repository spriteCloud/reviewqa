{
  "name": "wwwspritecloudcom-e2e",
  "private": true,
  "type": "module",
  "description": "End-to-end tests using Playwright and Gherkin (via playwright-bdd), generated by ReviewQA for https://www.spritecloud.com.",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report",
    "test:smoke": "playwright test --grep @smoke",
    "test:critical": "playwright test --grep @priority:critical",
    "test:a11y": "playwright test --grep @kind:a11y",
    "test:perf": "playwright test --grep @kind:perf",
    "test:security": "playwright test --grep @kind:security",
    "test:health": "playwright test --grep @kind:health",
    "test:contract": "playwright test --grep @kind:contract",
    "test:visual": "playwright test --grep @kind:visual",
    "test:visual-update": "playwright test --grep @kind:visual --update-snapshots",
    "test:graphql": "playwright test --grep @kind:graphql",
    "test:webhook": "playwright test --grep @kind:webhook",
    "test:install-browser": "playwright install chromium firefox webkit"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "playwright-bdd": "^7.4.0",
    "@axe-core/playwright": "^4.10.0"
  }
}
