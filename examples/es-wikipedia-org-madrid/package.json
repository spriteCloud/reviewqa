{
  "name": "eswikipediaorg-e2e",
  "private": true,
  "type": "module",
  "description": "Playwright + Gherkin (playwright-bdd) e2e suite generated by reviewqa for https://es.wikipedia.org.",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report",
    "test:smoke": "playwright test --grep @smoke",
    "test:critical": "playwright test --grep @priority:critical",
    "test:install-browser": "playwright install chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "playwright-bdd": "^7.4.0"
  }
}
